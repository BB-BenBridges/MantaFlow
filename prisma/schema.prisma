generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas   = ["gantt"]
}

enum TaskStatus {
  accent
  good
  warn
  idle

  @@schema("gantt")
}

enum SubtaskStatus {
  todo
  inProgress
  complete

  @@schema("gantt")
}

model Board {
  id        String    @id @default(cuid())
  name      String
  order     Int       @default(0)
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@schema("gantt")
}

model Task {
  id          String     @id @default(cuid())
  name        String
  description String?
  person      String?
  initials    String
  status      TaskStatus @default(good)
  startDate   DateTime?
  endDate     DateTime?
  order       Int        @default(0)
  board       Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId     String
  subtasks    Subtask[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@schema("gantt")
}

model Subtask {
  id          String        @id @default(cuid())
  name        String
  description String?
  person      String?
  initials    String
  start       DateTime
  end         DateTime
  status      SubtaskStatus @default(todo)
  order       Int           @default(0)
  task        Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@schema("gantt")
}
