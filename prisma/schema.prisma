generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas   = ["gantt"]
}

enum ProjectStatus {
  accent
  good
  warn
  idle

  @@schema("gantt")
}

enum TaskStatus {
  todo
  inProgress
  complete

  @@schema("gantt")
}

model Board {
  id        String    @id @default(cuid())
  name      String
  order     Int       @default(0)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@schema("gantt")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  person      String?
  initials    String
  status      ProjectStatus @default(good)
  startDate   DateTime?
  endDate     DateTime?
  order       Int           @default(0)
  board       Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId     String
  tasks       Task[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@schema("gantt")
}

model Task {
  id          String   @id @default(cuid())
  name        String
  description String?
  person      String?
  initials    String
  start       DateTime
  end         DateTime
  status      TaskStatus @default(todo)
  order       Int      @default(0)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("gantt")
}
